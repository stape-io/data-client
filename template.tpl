- name: '[Cookie Consent] Consent granted scenarios - setCookie is called'
  code: |-
    mock('getRequestPath', '/data');
    mock('getRequestMethod', 'POST');

    const cleanup = () => {
      mock('getCookieValues', () => []);
    };

    [
      {
        description: 'no cookieStorageMode - consent not declined',
        dataOverrides: {},
        body: '{"event":"page_view","client_id":"cid_123"}'
      },
      {
        description: 'auto mode - consent_state analytics_storage granted',
        dataOverrides: { cookieStorageMode: 'auto', cookieConsentAutoParameter: 'analytics_storage' },
        body: '{"event":"page_view","client_id":"cid_123","consent_state":{"analytics_storage":true}}'
      },
      {
        description: 'auto mode - no autoConsentParameter - consent not declined',
        dataOverrides: { cookieStorageMode: 'auto' },
        body: '{"event":"page_view","client_id":"cid_123","consent_state":{"analytics_storage":false}}'
      },
      {
        description: 'manual mode - granted value',
        dataOverrides: { cookieStorageMode: 'manual', cookieConsentManualValue: 'granted' },
        body: '{"event":"page_view","client_id":"cid_123"}'
      }
    ].forEach(scenario => {
      cleanup();

      const copyMockData = JSON.parse(JSON.stringify(mockData));
      mergeObj(copyMockData, scenario.dataOverrides);

      mock('getRequestBody', scenario.body);

      let claimRequestWasCalled;
      mock('claimRequest', () => { claimRequestWasCalled = true; });
      mock('runContainer', (eventData, onCompleteCallback) => { onCompleteCallback(); });

      runCode(copyMockData);

      callLater(() => {
        assertThat(claimRequestWasCalled).isTrue();
        assertApi('setCookie').wasCalled();
        assertApi('returnResponse').wasCalled();
      });
    });
setup: |-
  const JSON = require('JSON');
  const Object = require('Object');
  const callLater = require('callLater');

  function mergeObj(target, source) {
    for (const key in source) {
      if (source.hasOwnProperty(key)) target[key] = source[key];
    }
    return target;
  }

  const mockData = {
    responseStatusCode: 200,
    generateClientId: true,
    responseBody: 'timestamp',
    prolongCookies: true,
    httpOnlyCookie: false,
    responseBodyGet: false,
    acceptMultipleEvents: false,
    exposeFPIDCookie: false
  };

  mock('getRequestHeader', (header) => {
    if (header === 'trace-id') return 'expectedTraceId';
  });

  mock('getTimestampMillis', 1747945830456);

  mock('generateRandom', 123456789);


